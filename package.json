{
  "name": "nextjs-tailwind4-template",
  "version": "1.0.2",
  "private": true,
  "scripts": {
    "dev": "run-p dev:*",
    "dev:next": "next dev",
    "dev:path": "pathpida --ignorePath .gitignore --watch",
    "build": "pathpida --ignorePath .gitignore && next build",
    "start": "next start",
    "lint": "biome check ./src --error-on-warnings",
    "format": "biome format --write ./src",
    "fix": "biome check --write ./src",
    "type-check": "tsc --noEmit --project tsconfig.json"
  },
  "dependencies": {
    "next": "^16.2.2",
    "npm-run-all": "^4.1.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "lefthook": "^2.1.5",
    "pathpida": "^0.26.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2"
  },
  "overrides": {
    "picomatch": "^4.0.4"
  }
}
